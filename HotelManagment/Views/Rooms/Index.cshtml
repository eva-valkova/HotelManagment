<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="~/css/rooms.css"> <title>Our Rooms - Velvet & Vine</title>
</head>
<body>

<div class="rooms-container">
    <div class="section-header">
        <h2>Exquisite Accommodations</h2>
        <p>Discover the perfect blend of comfort and luxury</p>
    </div>

    <div class="rooms-grid">
        <div class="room-card">
            <div class="room-image" style="background-image: url('/images/single-twin.jpg');">
                <span class="room-badge">Popular</span>
            </div>
            <div class="room-info">
                <h3>Standard Twin Room</h3>
                <ul class="room-features">
                    <li>2 Single Beds</li>
                    <li>City View</li>
                    <li>Free Wi-Fi</li>
                </ul>
                <div class="room-price">From $85 / night</div>
            </div>
            <a href="/Reservations/Create?type=Single" class="btn-reserve">Book Now</a>
        </div>

        <div class="room-card">
            <div class="room-image" style="background-image: url('/images/apartment.jpg');"></div>
            <div class="room-info">
                <h3>Luxury Apartment</h3>
                <ul class="room-features">
                    <li>Living Area & Kitchen</li>
                    <li>Perfect for Families</li>
                    <li>Garden View</li>
                </ul>
                <div class="room-price">From $150 / night</div>
            </div>
            <a href="/Reservations/Create?type=Apartment" class="btn-reserve">Book Now</a>
        </div>

        <div class="room-card">
            <div class="room-image" style="background-image: url('/images/double.jpg');"></div>
            <div class="room-info">
                <h3>Deluxe Double Room</h3>
                <ul class="room-features">
                    <li>King Size Bed</li>
                    <li>Perfect for Couples</li>
                    <li>Mini Bar</li>
                </ul>
                <div class="room-price">From $110 / night</div>
            </div>
            <a href="/Reservations/Create?type=Double" class="btn-reserve">Book Now</a>
        </div>

        <div class="room-card">
            <div class="room-image" style="background-image: url('/images/penthouse.jpg');">
                <span class="room-badge">VIP</span>
            </div>
            <div class="room-info">
                <h3>Royal Penthouse</h3>
                <ul class="room-features">
                    <li>Panoramic Sea View</li>
                    <li>Private Terrace</li>
                    <li>Personal Concierge</li>
                </ul>
                <div class="room-price">From $450 / night</div>
            </div>
            <a href="/Reservations/Create?type=Penthouse" class="btn-reserve">Book Now</a>
        </div>

        <div class="room-card">
            <div class="room-image" style="background-image: url('/images/maisonette.jpg');"></div>
            <div class="room-info">
                <h3>Grand Maisonette</h3>
                <ul class="room-features">
                    <li>Two Floors</li>
                    <li>Internal Staircase</li>
                    <li>Maximum Space</li>
                </ul>
                <div class="room-price">From $320 / night</div>
            </div>
            <a href="/Reservations/Create?type=Maisonette" class="btn-reserve">Book Now</a>
        </div>
    </div>
</div>

</body>
</html>